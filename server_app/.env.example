# Скопируйте в .env и подставьте значения (файл .env в git не коммитить).

# Обязательно в продакшене (случайная строка 50+ символов):
# DJANGO_SECRET_KEY=

# Локально / первые тесты: True. Продакшен на VPS: False
DJANGO_DEBUG=True

# Через запятую: IP, домен, localhost (нужно при DJANGO_DEBUG=False)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Пока без nginx + HTTPS на сервере — 0/false. С TLS за прокси — 1/true
DJANGO_USE_HTTPS=False

# Если открываете админку по https://example.com — укажите источники для CSRF:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
